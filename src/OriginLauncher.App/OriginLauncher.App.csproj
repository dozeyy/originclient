<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Assets\origin.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CmlLib.Core" Version="4.0.6" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.4022.49" />
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="10.0.9" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\origin.ico" />
    <!-- Version-select grid card artwork (one per version family). -->
    <Resource Include="Assets\Versions\*.png" />
  </ItemGroup>

  <!--
    Bundles each src/mods module's Gradle build output into the launcher's
    output directory (as Bundled/OriginClient/originclient-<mcver>.jar, read at
    runtime via OriginPaths.BundledOriginClientJar) so a Fabric instance the
    launcher provisions can be pre-loaded with the Origin Client build matching
    the chosen Minecraft version — no separate manual copy step, and whatever
    tool packages this output into a setup installer picks the jars up along
    with everything else. VersionManager's OriginBuilds registry maps each MC
    version to the bundled filename here.

    Each source filename is pinned to the exact mod_version in that module's
    gradle.properties rather than a wildcard: a glob risks matching a stale jar
    left behind from a prior version bump if build/libs isn't cleaned, which
    would break the build with an ambiguous duplicate match. Bump these
    alongside each module's mod_version.

    Conditional on each jar existing so a fresh checkout (or a launcher-only
    change) still builds before ./gradlew build has been run in that module —
    the launcher already fail-softs at runtime when a bundled jar is absent
    (VersionManager falls back to the standalone perf-mod catalog for that
    version). A RELEASE build must still verify the jars are present.

    Every jar is kept LOOSE next to the exe in a single-file publish. Without
    ExcludeFromSingleFile it gets embedded in the bundle and extracted to a temp
    dir, while OriginPaths.BundledOriginClientJar looks in AppContext.BaseDirectory
    (the exe's own folder) — so File.Exists is false, the launcher thinks the
    mod isn't bundled, and it falls back to the standalone perf-mod catalog (a
    stray Sodium that breaks Iris). Loose = the path resolves.
  -->
  <ItemGroup>
    <!-- 1.21.1 STOCK — full Origin build, self-contained perf stack (jar-in-jar):
         Sodium 0.6.13 + Indium + Iris 1.8.8. Default install. -->
    <Content Condition="Exists('..\mods\versions\1.21.1\build\libs\originclient-0.4.2.jar')"
             Include="..\mods\versions\1.21.1\build\libs\originclient-0.4.2.jar">
      <Link>Bundled\OriginClient\originclient-1.21.1.jar</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- 1.20 / 1.20.1 — Origin client only; perf stack installed standalone. -->
    <Content Condition="Exists('..\mods\versions\1.20\build\libs\originclient-1.20-0.4.1.jar')"
             Include="..\mods\versions\1.20\build\libs\originclient-1.20-0.4.1.jar">
      <Link>Bundled\OriginClient\originclient-1.20.jar</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- 1.20.4 — Origin client only; perf stack installed standalone. -->
    <Content Condition="Exists('..\mods\versions\1.20.4\build\libs\originclient-1.20.4-0.4.1.jar')"
             Include="..\mods\versions\1.20.4\build\libs\originclient-1.20.4-0.4.1.jar">
      <Link>Bundled\OriginClient\originclient-1.20.4.jar</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- 1.21 — Origin client only; perf/shader stack installed standalone.
         Same source as 1.21.1 (pre-1.21.2 blit API); its own 1.21-mapped jar. -->
    <Content Condition="Exists('..\mods\versions\1.21\build\libs\originclient-1.21-0.4.1.jar')"
             Include="..\mods\versions\1.21\build\libs\originclient-1.21-0.4.1.jar">
      <Link>Bundled\OriginClient\originclient-1.21.jar</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- 1.21.5 — own sub-family build (blit-rework + HitboxRenderState era). -->
    <Content Condition="Exists('..\mods\versions\1.21.5\build\libs\originclient-1.21.5-0.4.1.jar')"
             Include="..\mods\versions\1.21.5\build\libs\originclient-1.21.5-0.4.1.jar">
      <Link>Bundled\OriginClient\originclient-1.21.5.jar</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- 1.21.8 — own sub-family build (Matrix3x2fStack + no-setShaderColor era). -->
    <Content Condition="Exists('..\mods\versions\1.21.8\build\libs\originclient-1.21.8-0.4.1.jar')"
             Include="..\mods\versions\1.21.8\build\libs\originclient-1.21.8-0.4.1.jar">
      <Link>Bundled\OriginClient\originclient-1.21.8.jar</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- 1.21.10 + 1.21.11 — one jar for the render-pipeline + world-event-v2
         era; Origin client only, perf/shader stack installed standalone. LIVE. -->
    <Content Condition="Exists('..\mods\versions\1.21.11\build\libs\originclient-1.21.11-0.4.1.jar')"
             Include="..\mods\versions\1.21.11\build\libs\originclient-1.21.11-0.4.1.jar">
      <Link>Bundled\OriginClient\originclient-1.21.11.jar</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- 26.2 — Origin client only; perf/shader stack installed standalone. -->
    <Content Condition="Exists('..\mods\staged\26.2\build\libs\originclient-26.2-0.4.1.jar')"
             Include="..\mods\staged\26.2\build\libs\originclient-26.2-0.4.1.jar">
      <Link>Bundled\OriginClient\originclient-26.2.jar</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- Gap sub-families staged 2026-07-13 — compile-verified, bundled for local
         boot-testing. 1.21.4 jar covers 1.21.2/3/4; 1.21.6 jar covers 1.21.6/7. -->
    <Content Condition="Exists('..\mods\versions\1.20.2\build\libs\originclient-1.20.2-0.4.1.jar')"
             Include="..\mods\versions\1.20.2\build\libs\originclient-1.20.2-0.4.1.jar">
      <Link>Bundled\OriginClient\originclient-1.20.2.jar</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <Content Condition="Exists('..\mods\versions\1.21.4\build\libs\originclient-1.21.4-0.4.1.jar')"
             Include="..\mods\versions\1.21.4\build\libs\originclient-1.21.4-0.4.1.jar">
      <Link>Bundled\OriginClient\originclient-1.21.4.jar</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <Content Condition="Exists('..\mods\versions\1.21.6\build\libs\originclient-1.21.6-0.4.1.jar')"
             Include="..\mods\versions\1.21.6\build\libs\originclient-1.21.6-0.4.1.jar">
      <Link>Bundled\OriginClient\originclient-1.21.6.jar</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- 1.21.10 split from 1.21.11 (own sub-family; the 1.21.11 mapping rename wave). -->
    <Content Condition="Exists('..\mods\versions\1.21.10\build\libs\originclient-1.21.10-0.4.1.jar')"
             Include="..\mods\versions\1.21.10\build\libs\originclient-1.21.10-0.4.1.jar">
      <Link>Bundled\OriginClient\originclient-1.21.10.jar</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
  </ItemGroup>

</Project>
