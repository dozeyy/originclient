<UserControl x:Class="OriginLauncher.App.UI.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:OriginLauncher.App.UI.Controls"
             mc:Ignorable="d">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- Opens the full-screen version picker (VersionSelectOverlay).
                 Shows the current selection; the grid does the real choosing. -->
            <Button x:Name="VersionButton" Style="{StaticResource Button.Secondary}"
                    MinWidth="220" Margin="0,0,0,12" Padding="16,9"
                    HorizontalContentAlignment="Stretch" Click="VersionButton_Click">
                <Grid>
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="VERSION" Style="{StaticResource Text.Eyebrow}"/>
                        <TextBlock x:Name="VersionButtonText" Text="—" Style="{StaticResource Text.Body}" Margin="0,1,0,0"/>
                    </StackPanel>
                    <Path Data="M0,0 L5,5 L10,0" Stroke="{StaticResource Brush.TextDim}" StrokeThickness="1.7"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Width="10" Height="5" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </Grid>
            </Button>

            <!-- Loader: exactly two options per version — Vanilla + Fabric where
                 the perf-mod catalog has data, or Vanilla + Forge (with OptiFine)
                 below that floor. A StackPanel (not a Grid) so the hidden third
                 toggle takes up no space instead of leaving a gap. -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Center">
                <ToggleButton x:Name="LoaderVanillaToggle" Style="{StaticResource Button.NavItem}"
                              Content="VANILLA" Padding="14,7" HorizontalContentAlignment="Center" Margin="0,0,6,0"
                              Checked="LoaderVanillaToggle_Checked"/>
                <ToggleButton x:Name="LoaderFabricToggle" Style="{StaticResource Button.NavItem}"
                              Content="FABRIC" Padding="14,7" HorizontalContentAlignment="Center"
                              Checked="LoaderFabricToggle_Checked"/>
                <ToggleButton x:Name="LoaderForgeToggle" Style="{StaticResource Button.NavItem}"
                              Content="FORGE" Padding="14,7" HorizontalContentAlignment="Center"
                              Checked="LoaderForgeToggle_Checked"/>
            </StackPanel>

            <!-- Only shown when Forge is the active choice. Downloaded via
                 OptiFineCatalog (BMCLAPI mirror) on click — OptiFine itself has
                 no official API and gates downloads behind an ad page. -->
            <Grid x:Name="OptiFineRow" Margin="0,0,0,18" Visibility="Collapsed" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="OptiFine" Style="{StaticResource Text.BodyDim}" VerticalAlignment="Center"/>
                <ToggleButton Grid.Column="2" x:Name="OptiFineToggle" Style="{StaticResource Toggle.Switch}"
                              VerticalAlignment="Center"
                              Checked="OptiFineToggle_Checked" Unchecked="OptiFineToggle_Unchecked"/>
            </Grid>

            <Button x:Name="PlayButton" Content="PLAY"
                    Style="{StaticResource Button.PlayHero}"
                    IsEnabled="False"
                    ToolTip="Sign in and select a version to play"
                    Click="PlayButton_Click"/>

            <TextBlock x:Name="StatusText" Text="No account signed in"
                       Style="{StaticResource Text.BodyDim}"
                       HorizontalAlignment="Center" Margin="0,20,0,0"/>
        </StackPanel>

        <!-- Version picker sits above Home content but below the launch overlay
             so a launch that starts while it's (somehow) open still covers it. -->
        <controls:VersionSelectOverlay x:Name="VersionOverlay"/>
        <controls:LaunchLoadingOverlay x:Name="LoadingOverlay"/>
        <!-- Topmost: a launch-blocking confirm (e.g. the Voxy/Sodium mismatch
             guard) must sit above the loading overlay. -->
        <controls:ConfirmOverlay x:Name="ConfirmOverlay"/>
    </Grid>
</UserControl>
