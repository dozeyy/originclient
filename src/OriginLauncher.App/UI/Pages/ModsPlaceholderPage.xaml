<UserControl x:Class="OriginLauncher.App.UI.Pages.ModsPlaceholderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="360">
        <Path Data="{StaticResource Icon.Mods}" Style="{StaticResource Icon.Base}"
              Width="40" Height="40" Stroke="{StaticResource Brush.TextMuted}"
              HorizontalAlignment="Center" Margin="0,0,0,16"/>
        <TextBlock Text="Mods are coming soon" Style="{StaticResource Text.H2}"
                    HorizontalAlignment="Center" Margin="0,0,0,8"/>
        <TextBlock Text="Fabric, Forge, and OptiFine support land once version handling is in place."
                    Style="{StaticResource Text.BodyDim}" TextWrapping="Wrap"
                    HorizontalAlignment="Center" TextAlignment="Center"/>
    </StackPanel>
</UserControl>
