<UserControl x:Class="OriginLauncher.App.UI.Controls.MicrosoftSignInPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="20,16,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Sign in with Microsoft" Style="{StaticResource Text.H2}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Style="{StaticResource Button.Chrome}" Width="28" Height="28" Padding="6"
                    Click="CancelButton_Click" ToolTip="Cancel sign-in">
                <Path Data="{StaticResource Icon.Close}" Style="{StaticResource Icon.Base}"
                      Width="12" Height="12" Stroke="{StaticResource Brush.TextDim}"/>
            </Button>
        </Grid>

        <!-- Body: the embedded Microsoft login page. WebView starts transparent-covered
             by LoadingText until the first navigation completes, so the user never
             sees a blank white flash while CoreWebView2 spins up. -->
        <Grid Grid.Row="1" Margin="1,0,1,1" ClipToBounds="True">
            <wv2:WebView2 x:Name="WebView" DefaultBackgroundColor="#1A1A1A"/>
            <Border x:Name="LoadingOverlay" Background="{StaticResource Brush.Panel}">
                <TextBlock x:Name="LoadingText" Text="Loading sign-in..." Style="{StaticResource Text.BodyDim}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
