<UserControl x:Class="OriginLauncher.App.UI.Controls.AccountSwitcherPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:OriginLauncher.App.Core.Models"
             mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="AccountRow" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Card}"/>
            <Setter Property="CornerRadius" Value="{StaticResource Radius.Row}"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush.CardAlt}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="20,20,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Accounts" Style="{StaticResource Text.H2}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Style="{StaticResource Button.Chrome}" Width="28" Height="28" Padding="6"
                    Click="CloseButton_Click">
                <Path Data="{StaticResource Icon.Close}" Style="{StaticResource Icon.Base}"
                      Width="12" Height="12" Stroke="{StaticResource Brush.TextDim}"/>
            </Button>
        </Grid>

        <!-- Account list / empty state -->
        <Grid Grid.Row="1" Margin="20,0">
            <TextBlock x:Name="EmptyStateText"
                       Text="No accounts added yet. Add a Microsoft account to sign in."
                       Style="{StaticResource Text.BodyDim}"
                       TextWrapping="Wrap" VerticalAlignment="Top"/>

            <ItemsControl x:Name="AccountList" Visibility="Collapsed">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:MinecraftAccount}">
                        <Border Style="{StaticResource AccountRow}" MouseLeftButtonDown="AccountRow_MouseLeftButtonDown">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                        Background="{StaticResource Brush.CardAlt}" Margin="0,0,12,0">
                                    <Path Data="{StaticResource Icon.Account}" Style="{StaticResource Icon.Base}"
                                          Width="18" Height="18" Stroke="{StaticResource Brush.Text}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Gamertag}" Style="{StaticResource Text.Body}"/>
                                    <TextBlock Text="{Binding LastUsedUtc, StringFormat='Last used {0:MMM d, yyyy}'}"
                                               Style="{StaticResource Text.Label}" FontSize="11"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="ACTIVE" Style="{StaticResource Text.Eyebrow}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- Sign-in error -->
        <TextBlock Grid.Row="2" x:Name="ErrorText" Style="{StaticResource Text.Body}"
                   Foreground="{StaticResource Brush.Danger}" TextWrapping="Wrap"
                   Margin="20,0,20,12" Visibility="Collapsed"/>

        <!-- Add account -->
        <Button Grid.Row="3" x:Name="AddAccountButton" Content="ADD MICROSOFT ACCOUNT" Style="{StaticResource Button.Primary}"
                Margin="20" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                Click="AddAccountButton_Click"/>
    </Grid>
</UserControl>
