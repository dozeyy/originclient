<UserControl x:Class="OriginLauncher.App.UI.Controls.ConfirmOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Visibility="Collapsed"
             IsHitTestVisible="True">

    <!-- Modal confirm dialog in the launcher's own visual language (a layered
         card over a dim scrim), not a Win32 MessageBox. Awaited via ShowAsync;
         Primary returns true, Secondary/Esc returns false. -->
    <Border Background="#B3121212">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="440" Margin="24"
                Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Stroke}" BorderThickness="1"
                CornerRadius="10" Padding="28,26">
            <StackPanel>
                <TextBlock x:Name="TitleText" Style="{StaticResource Text.H2}" TextWrapping="Wrap"/>
                <TextBlock x:Name="MessageText" Style="{StaticResource Text.BodyDim}"
                           TextWrapping="Wrap" Margin="0,10,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                    <Button x:Name="SecondaryButton" Style="{StaticResource Button.Secondary}"
                            Padding="16,7" Margin="0,0,10,0" Click="SecondaryButton_Click"/>
                    <Button x:Name="PrimaryButton" Style="{StaticResource Button.Primary}"
                            Padding="16,7" Click="PrimaryButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Border>
</UserControl>
