<UserControl x:Class="OriginLauncher.App.UI.Controls.OriginMark"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <!--
        Three tilted original rings sharing one center (atom/origin pattern):
        same ellipse, rotated 0/60/120 degrees, different sizes so they read
        as distinct rings rather than one thick line. Static mark — the
        animated background system (OriginBackground) reuses this visual
        language at a larger scale with continuous rotation, but is a
        separate control since the two have nothing else in common.
    -->
    <Viewbox Stretch="Uniform">
        <Grid Width="200" Height="200" Effect="{StaticResource Effect.OriginGlow}">
            <Ellipse Width="180" Height="64" Stroke="{StaticResource Brush.Text}"
                     StrokeThickness="3" Fill="Transparent"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <RotateTransform Angle="0"/>
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse Width="150" Height="54" Stroke="{StaticResource Brush.Text}"
                     StrokeThickness="3" Fill="Transparent"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <RotateTransform Angle="60"/>
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse Width="120" Height="44" Stroke="{StaticResource Brush.Text}"
                     StrokeThickness="3" Fill="Transparent"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <RotateTransform Angle="120"/>
                </Ellipse.RenderTransform>
            </Ellipse>
        </Grid>
    </Viewbox>
</UserControl>
