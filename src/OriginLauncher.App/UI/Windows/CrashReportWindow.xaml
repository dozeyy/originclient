<Window x:Class="OriginLauncher.App.UI.Windows.CrashReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Origin — Minecraft crashed"
        Width="620" Height="480" MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="#FF121212"
        FontFamily="Bahnschrift, Segoe UI Variable Text, Segoe UI">

    <!-- Self-contained styling (hardcoded, no theme StaticResources), same
         rule as CrashWindow: a crash surface must render no matter what. -->
    <Window.Resources>
        <Style x:Key="CrashButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="Background" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="7" SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#FF505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CrashButtonPrimary" TargetType="Button" BasedOn="{StaticResource CrashButton}">
            <Setter Property="Background" Value="#FFE0E0E0"/>
            <Setter Property="Foreground" Value="#FF121212"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="7" SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#FFEDEDED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Minecraft crashed while starting"
                   Foreground="#FFE0E0E0" FontSize="22" FontWeight="SemiBold"/>

        <TextBlock Grid.Row="1" x:Name="ReasonText" Foreground="#FFB0B0B0" FontSize="13"
                   TextWrapping="Wrap" Margin="0,8,0,0"/>

        <!-- One row per implicated mod; hidden when the culprit is unknown. -->
        <Border Grid.Row="2" x:Name="CulpritPanel" Margin="0,12,0,0" Background="#FF1A1A1A"
                BorderBrush="#FF3A3A3A" BorderThickness="1" CornerRadius="7" Padding="12"
                Visibility="Collapsed">
            <StackPanel x:Name="CulpritList"/>
        </Border>

        <Border Grid.Row="3" Margin="0,12,0,0" Background="#FF1A1A1A" BorderBrush="#FF3A3A3A"
                BorderThickness="1" CornerRadius="7">
            <TextBox x:Name="DetailsBox" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                     Background="Transparent" Foreground="#FFB0B0B0" BorderThickness="0"
                     FontFamily="Consolas, Cascadia Mono, Courier New" FontSize="11" Padding="12"
                     TextWrapping="NoWrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="OpenLogButton" Content="Open log" Style="{StaticResource CrashButton}"
                    Margin="0,0,8,0" Click="OpenLog_Click"/>
            <Button x:Name="CloseButton" Content="Close" Style="{StaticResource CrashButton}"
                    Margin="0,0,8,0" Click="Close_Click"/>
            <Button x:Name="RetryButton" Content="Disable external mods &amp; retry"
                    Style="{StaticResource CrashButtonPrimary}" Click="Retry_Click"/>
        </StackPanel>
    </Grid>
</Window>
