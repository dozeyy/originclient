<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="Font.Primary">Bahnschrift, Segoe UI Variable Text, Segoe UI</FontFamily>

    <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib" x:Key="FontSize.H1">22</system:Double>
    <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib" x:Key="FontSize.H2">15</system:Double>
    <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib" x:Key="FontSize.Body">13</system:Double>
    <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib" x:Key="FontSize.Eyebrow">11</system:Double>

    <Style x:Key="Text.H1" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.H1}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="Text.H2" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.H2}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.Body}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="Text.BodyDim" TargetType="TextBlock" BasedOn="{StaticResource Text.Body}">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextDim}"/>
    </Style>

    <Style x:Key="Text.Label" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.Body}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextDim}"/>
    </Style>

    <!-- TextBlock has no CharacterCasing property (TextBox-only) — author eyebrow content in caps -->
    <Style x:Key="Text.Eyebrow" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.Eyebrow}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}"/>
    </Style>

</ResourceDictionary>
