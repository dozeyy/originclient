<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- 8px spacing grid -->
    <system:Double x:Key="Space.1">4</system:Double>
    <system:Double x:Key="Space.2">8</system:Double>
    <system:Double x:Key="Space.3">16</system:Double>
    <system:Double x:Key="Space.4">24</system:Double>
    <system:Double x:Key="Space.5">32</system:Double>
    <system:Double x:Key="Space.6">48</system:Double>

    <!-- Corner radius tiers -->
    <CornerRadius x:Key="Radius.Chip">6</CornerRadius>
    <CornerRadius x:Key="Radius.Control">7</CornerRadius>
    <CornerRadius x:Key="Radius.NavItem">8</CornerRadius>
    <CornerRadius x:Key="Radius.Row">9</CornerRadius>
    <CornerRadius x:Key="Radius.Card">10</CornerRadius>
    <CornerRadius x:Key="Radius.Swatch">12</CornerRadius>

    <!-- Motion timing -->
    <Duration x:Key="Motion.Base">0:0:0.12</Duration>
    <Duration x:Key="Motion.Press">0:0:0.06</Duration>
    <Duration x:Key="Motion.Release">0:0:0.18</Duration>

    <!-- Primary action resting shadow — the only element allowed one -->
    <DropShadowEffect x:Key="Shadow.Primary"
                      Color="#FF000000"
                      Opacity="0.35"
                      BlurRadius="16"
                      ShadowDepth="4"
                      Direction="270"/>

</ResourceDictionary>
