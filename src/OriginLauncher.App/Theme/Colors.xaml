<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme (default). Monochrome — depth from lightness only, never hue. -->

    <Color x:Key="Color.Bg">#FF121212</Color>
    <Color x:Key="Color.Panel">#FF1A1A1A</Color>
    <Color x:Key="Color.Card">#FF444444</Color>
    <Color x:Key="Color.CardAlt">#FF505050</Color>
    <Color x:Key="Color.Stroke">#FF3A3A3A</Color>
    <Color x:Key="Color.SoftStroke">#FF282828</Color>

    <Color x:Key="Color.Text">#FFE0E0E0</Color>
    <Color x:Key="Color.TextDim">#FFB0B0B0</Color>
    <Color x:Key="Color.TextMuted">#FF888888</Color>

    <Color x:Key="Color.Accent">#FFE0E0E0</Color>
    <Color x:Key="Color.AccentHover">#FFEDEDED</Color>
    <Color x:Key="Color.AccentPress">#FFC9C9C9</Color>
    <Color x:Key="Color.TextOnAccent">#FF121212</Color>

    <!-- Alpha-0 variant of SoftStroke: same RGB as the hover target so a hover
         fade only animates alpha, never drifts white via RGB interpolation. -->
    <Color x:Key="Color.GhostRest">#00282828</Color>

    <Color x:Key="Color.Danger">#FFC77A73</Color>
    <Color x:Key="Color.DangerStrong">#FFB23A33</Color>
    <Color x:Key="Color.Success">#FF7FA98F</Color>
    <Color x:Key="Color.SuccessStrong">#FF2F7D53</Color>

    <!-- Brushes -->

    <SolidColorBrush x:Key="Brush.Bg" Color="{StaticResource Color.Bg}"/>
    <SolidColorBrush x:Key="Brush.Panel" Color="{StaticResource Color.Panel}"/>
    <SolidColorBrush x:Key="Brush.Card" Color="{StaticResource Color.Card}"/>
    <SolidColorBrush x:Key="Brush.CardAlt" Color="{StaticResource Color.CardAlt}"/>
    <SolidColorBrush x:Key="Brush.Stroke" Color="{StaticResource Color.Stroke}"/>
    <SolidColorBrush x:Key="Brush.SoftStroke" Color="{StaticResource Color.SoftStroke}"/>

    <SolidColorBrush x:Key="Brush.Text" Color="{StaticResource Color.Text}"/>
    <SolidColorBrush x:Key="Brush.TextDim" Color="{StaticResource Color.TextDim}"/>
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}"/>

    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}"/>
    <SolidColorBrush x:Key="Brush.AccentHover" Color="{StaticResource Color.AccentHover}"/>
    <SolidColorBrush x:Key="Brush.AccentPress" Color="{StaticResource Color.AccentPress}"/>
    <SolidColorBrush x:Key="Brush.TextOnAccent" Color="{StaticResource Color.TextOnAccent}"/>

    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}"/>
    <SolidColorBrush x:Key="Brush.DangerStrong" Color="{StaticResource Color.DangerStrong}"/>
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}"/>
    <SolidColorBrush x:Key="Brush.SuccessStrong" Color="{StaticResource Color.SuccessStrong}"/>

</ResourceDictionary>
