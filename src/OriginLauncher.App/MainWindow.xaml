<Window x:Class="OriginLauncher.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:OriginLauncher.App.UI.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Origin Launcher"
        Icon="Assets/origin.ico"
        Width="1180" Height="740"
        MinWidth="980" MinHeight="600"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{StaticResource Brush.Bg}"
        FontFamily="{StaticResource Font.Primary}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <!-- Ambient animated space field, bottom-most layer -->
        <controls:OriginBackground/>

        <!-- Chromeless content layer. Background=Transparent (not null) so
             empty space is still hit-testable for the drag-anywhere handler
             below; buttons/combo consume the click first, so this only
             fires when the click lands on genuinely empty background. -->
        <Grid Background="Transparent" MouseLeftButtonDown="RootGrid_MouseLeftButtonDown">

            <!-- Top margin reserves the strip occupied by the origin mark badge
                 and the account/minimize/close cluster (~48px tall) so page
                 content (e.g. Settings' H1 title) never renders under them.
                 No left margin here — Home/Mods center their own content and
                 a global left inset would throw off that centering; the
                 left-aligned Settings page reserves its own left clearance
                 for the floating icon column instead (see SettingsPage.xaml). -->
            <ContentControl x:Name="PageHost" Margin="0,64,0,0"/>

            <!-- Top-left: small static origin mark -->
            <controls:OriginMark Width="28" Height="28" Margin="20"
                                 HorizontalAlignment="Left" VerticalAlignment="Top"/>

            <!-- Top-right: account avatar + minimize/close cluster -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="16">
                <Button x:Name="AccountButton" Click="AccountButton_Click"
                        Style="{StaticResource Button.Chrome}"
                        Padding="8" Margin="0,0,4,0" Width="32" Height="32">
                    <Path Data="{StaticResource Icon.Account}" Style="{StaticResource Icon.Base}"
                          Width="16" Height="16" Stroke="{StaticResource Brush.Text}"/>
                </Button>
                <Button Click="MinimizeButton_Click" Style="{StaticResource Button.Chrome}"
                        Padding="8" Width="32" Height="32">
                    <Path Data="{StaticResource Icon.Minimize}" Style="{StaticResource Icon.Base}"
                          Width="12" Height="12" Stroke="{StaticResource Brush.TextDim}"/>
                </Button>
                <Button Click="CloseButton_Click" Style="{StaticResource Button.Chrome}"
                        Padding="8" Width="32" Height="32">
                    <Path Data="{StaticResource Icon.Close}" Style="{StaticResource Icon.Base}"
                          Width="12" Height="12" Stroke="{StaticResource Brush.TextDim}"/>
                </Button>
            </StackPanel>

            <!-- Left edge: floating secondary-nav icon column -->
            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0">
                <ToggleButton x:Name="NavHome" Style="{StaticResource Button.NavItem}"
                              Checked="NavHome_Checked" Width="36" Height="36" Padding="0"
                              HorizontalContentAlignment="Center" ToolTip="Home" Margin="0,0,0,8">
                    <Path Data="{StaticResource Icon.Home}" Style="{StaticResource Icon.Base}"
                          Width="18" Height="18" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                </ToggleButton>
                <ToggleButton x:Name="NavMods" Style="{StaticResource Button.NavItem}"
                              Checked="NavMods_Checked" Width="36" Height="36" Padding="0"
                              HorizontalContentAlignment="Center" ToolTip="Mods" Margin="0,0,0,8">
                    <Path Data="{StaticResource Icon.Mods}" Style="{StaticResource Icon.Base}"
                          Width="18" Height="18" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                </ToggleButton>
                <ToggleButton x:Name="NavSettings" Style="{StaticResource Button.NavItem}"
                              Checked="NavSettings_Checked" Width="36" Height="36" Padding="0"
                              HorizontalContentAlignment="Center" ToolTip="Settings">
                    <Path Data="{StaticResource Icon.Settings}" Style="{StaticResource Icon.Base}"
                          Width="18" Height="18" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                </ToggleButton>
            </StackPanel>
        </Grid>

        <!-- Account switcher overlay (scrim + slide-out panel) -->
        <Border x:Name="Scrim" Background="#000000" Opacity="0" IsHitTestVisible="False"
                MouseLeftButtonDown="Scrim_MouseLeftButtonDown"/>

        <Border x:Name="AccountPanel" Width="320" HorizontalAlignment="Right"
                Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Stroke}" BorderThickness="1,0,0,0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="AccountPanelTransform" X="320"/>
            </Border.RenderTransform>
            <ContentControl x:Name="AccountPanelHost"/>
        </Border>
    </Grid>
</Window>
