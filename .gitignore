# .NET
bin/
obj/
*.user

# Gradle / Java
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# IDE
.vs/
.idea/
*.suo

# OS
Thumbs.db
.DS_Store

# .NET publish output
publish/

# Font atlas generator scratch output (canonical copies live under
# src/mods/shared/.../assets/originclient/textures/font/)
tools/font-atlas/output/

# Loading-screen generator scratch previews (canonical textures live under
# src/mods/shared/.../assets/originclient/textures/ui/)
tools/loading-screen/*preview*.png
tools/loading-screen/loading_preview.png

# Python
__pycache__/

# Button generator scratch mockups
tools/buttons/*mock*.png
tools/loading-screen/*check*.png

# Dev-only third-party mod jars for runClient shader-integration testing
# (matches the launcher's PerformanceModCatalog pins) — never bundled into the
# shipping originclient jar, never committed.
src/mods/*/*/libs/

# Gradle runClient working dir (world saves, logs, crash-reports, per-run
# config) — dev runtime scratch, never source.
src/mods/*/*/run/

# Inno Setup installer output (built in CI from installer/OriginLauncher.iss).
installer/Output/

# Loading-screen generator scratch output dir.
tools/loading-screen/out/
